# Copy to .env for local dev (do NOT commit real values).
# In production these are set in the Render dashboard.

# Supabase project URL (e.g. https://osgxfggpqecspyvfrvqe.supabase.co)
SUPABASE_URL=
# Service role key — full DB/storage access. Server-side only, never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Anon/publishable key — used only to verify caller access tokens.
SUPABASE_ANON_KEY=
# Google Gemini API key.
GEMINI_API_KEY=
# Comma-separated allowed browser origins for CORS (e.g. https://app.example.com,http://localhost:8080). Use * to allow all.
ALLOWED_ORIGINS=*
# Local port (Render sets PORT automatically).
PORT=8080
